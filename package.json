{
  "name": "gymek",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter gymek-web dev",
    "dev:api": "pnpm --filter gymek-api dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter gymek-api build",
    "build:web": "pnpm --filter gymek-web build",
    "start:api": "pnpm --filter gymek-api start",
    "start:web": "pnpm --filter gymek-web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
